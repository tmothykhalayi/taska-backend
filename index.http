### ==================== HEALTH + DOCS ====================

### Health check
GET {{baseUrl}}/

### Swagger docs (should return HTML)
GET {{baseUrl}}/api/docs

### OpenAPI JSON (should return JSON)
GET {{baseUrl}}/api/docs-json


### ==================== AUTH ====================

### Register tasker user
# @name register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}",
  "firstName": "John",
  "lastName": "Doe",
  "phoneNumber": "+254700000000",
  "role": "tasker"
}

### Register admin user
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "nandwatimothykhalayi1@gmail.com",
  "password": "AdminPass123!",
  "firstName": "Admin",
  "lastName": "User",
  "phoneNumber": "+254711111111",
  "role": "admin",
  "status": "active"
}

### Login
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Refresh access token
POST {{baseUrl}}/auth/refresh
Authorization: Bearer {{refreshToken}}

### Sign out
POST {{baseUrl}}/auth/signout
Authorization: Bearer {{accessToken}}

### Forgot password
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "email": "{{email}}"
}

### Reset password
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "email": "{{email}}",
  "otp": "123456",
  "newPassword": "NewPassword789!"
}


### ==================== USERS ====================

### Create user
POST {{baseUrl}}/users
Content-Type: application/json

{
  "name": "Jane Doe",
  "email": "jane@example.com",
  "password": "Password123!",
  "role": "tasker",
  "status": "active"
}

### Get all users
GET {{baseUrl}}/users

### Get user by ID
GET {{baseUrl}}/users/{{userId}}

### Update user by ID
PATCH {{baseUrl}}/users/{{userId}}
Content-Type: application/json

{
  "name": "Jane Updated",
  "status": "active"
}

### Delete user by ID
DELETE {{baseUrl}}/users/{{userId}}


### ==================== TASKS ====================

### Create task
POST {{baseUrl}}/tasks
Content-Type: application/json

{
  "title": "Complete project setup",
  "description": "Set up backend and run endpoint checks",
  "priority": "high",
  "status": "pending",
  "category": "work",
  "dueDate": "2026-04-10T10:00:00.000Z",
  "userId": {{userId}}
}

### Get all tasks
GET {{baseUrl}}/tasks

### Get task by ID
GET {{baseUrl}}/tasks/{{taskId}}

### Update task by ID
PATCH {{baseUrl}}/tasks/{{taskId}}
Content-Type: application/json

{
  "status": "completed",
  "priority": "medium"
}

### Delete task by ID
DELETE {{baseUrl}}/tasks/{{taskId}}


### ==================== STREAKS ====================

### Create streak
POST {{baseUrl}}/streaks
Content-Type: application/json

{
  "userId": {{userId}},
  "lastCompletedDate": "2026-04-06T00:00:00.000Z"
}

### Get all streaks
GET {{baseUrl}}/streaks

### Get streak by ID
GET {{baseUrl}}/streaks/{{streakId}}

### Update user streak by userId
PATCH {{baseUrl}}/streaks/update/{{userId}}
Content-Type: application/json

{
  "completedToday": true
}

### Delete streak by ID
DELETE {{baseUrl}}/streaks/{{streakId}}


### ==================== BADGES ====================

### Create badge
POST {{baseUrl}}/badges
Content-Type: application/json

{
  "name": "3-Day Streak",
  "description": "Completed tasks for 3 consecutive days",
  "milestone": 3,
  "userId": {{userId}}
}

### Get all badges
GET {{baseUrl}}/badges

### Get badges by user ID
GET {{baseUrl}}/badges/user/{{userId}}

### Delete badge by ID
DELETE {{baseUrl}}/badges/{{badgeId}}


### ==================== QUOTES ====================

### Create quote
POST {{baseUrl}}/quotes
Content-Type: application/json

{
  "text": "Consistency compounds into results.",
  "author": "Taska"
}

### Get all quotes
GET {{baseUrl}}/quotes

### Get random quote
GET {{baseUrl}}/quotes/random

### Fetch and save quotes from API
POST {{baseUrl}}/quotes/fetch-from-api?limit=20

### Get quote by ID
GET {{baseUrl}}/quotes/{{quoteId}}

### Delete quote by ID
DELETE {{baseUrl}}/quotes/{{quoteId}}


### ==================== SETTINGS ====================

### Get settings
GET {{baseUrl}}/settings

### Update settings
PATCH {{baseUrl}}/settings
Content-Type: application/json

{
  "platformSettings": {
    "workspaceName": "Taska Workspace",
    "timezone": "Africa/Nairobi",
    "defaultTaskPriority": "medium",
    "reminderCadenceHours": 24,
    "overdueThresholdDays": 2,
    "autoArchiveCompletedDays": 30
  },
  "notificationSettings": {
    "emailDigest": true,
    "dueSoonAlerts": true,
    "overdueEscalation": false,
    "weeklySummaryDay": "monday"
  },
  "securitySettings": {
    "enforceTwoFactor": false,
    "sessionTimeoutMinutes": 60,
    "passwordRotationDays": 90,
    "loginAttemptLimit": 5
  }
}


### ==================== LOGS ====================

### Get all logs
GET {{baseUrl}}/logs

### Get logs by user ID
GET {{baseUrl}}/logs/user/{{userId}}
