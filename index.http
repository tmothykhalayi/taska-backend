### Login
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Refresh access token
POST {{baseUrl}}/auth/refresh
Authorization: Bearer {{refreshToken}}

### Sign out
POST {{baseUrl}}/auth/signout
Authorization: Bearer {{accessToken}}

### Forgot password
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "email": "{{email}}"
}

### Reset password
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "email": "{{email}}",
  "otp": "123456",
  "newPassword": "NewPassword789!"
}


### ==================== USERS ====================

### Create user
POST {{baseUrl}}/users
Content-Type: application/json

{
  "name": "Jane Doe",
  "email": "jane@example.com",
  "password": "Password123!",
  "role": "tasker",
  "status": "active"
}

### Get all users
GET {{baseUrl}}/users

### Then update the user IDs below based on the response above

### User IDs (UPDATE THESE BASED ON DATABASE):
### 1 = newtasker@example.com
### 2 = odhi@gmail.com
### 3 = timothykhalayi96@gmail.com
### 4 = nandwatimothykhalayi@gmail.com

### Update user by ID
PATCH {{baseUrl}}/users/{{userId}}
Content-Type: application/json

{
  "name": "Jane Updated",
  "status": "active"
}

### Delete user by ID
DELETE {{baseUrl}}/users/{{userId}}


### ==================== TASKS ====================

