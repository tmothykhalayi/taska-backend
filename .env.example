# Server
PORT=8000
NODE_ENV=production
APP_URL=https://your-backend-domain.com

# Frontend/CORS (comma-separated for multiple frontends)
FRONTEND_URL=https://your-frontend-domain.com
CORS_ORIGINS=https://your-frontend-domain.com

# Database (prefer DATABASE_URL in production)
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=taska
DB_SSL=true

# JWT
JWT_ACCESS_TOKEN_SECRET=
JWT_REFRESH_TOKEN_SECRET=

# Mail (optional depending on flow)
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=

# Security throttling
THROTTLE_TTL=60
THROTTLE_LIMIT=30
