<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Screening Decision</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }
        .header {
            background-color: #2c3e50;
            color: white;
            padding: 20px;
            text-align: center;
            border-radius: 5px 5px 0 0;
        }
        .header.approved {
            background-color: #28a745;
        }
        .header.rejected {
            background-color: #dc3545;
        }
        .header.conditional {
            background-color: #ffc107;
            color: #212529;
        }
        .content {
            background-color: #f8f9fa;
            padding: 30px;
            border: 1px solid #dee2e6;
        }
        .footer {
            background-color: #343a40;
            color: white;
            padding: 15px;
            text-align: center;
            border-radius: 0 0 5px 5px;
            font-size: 14px;
        }
        .decision-box {
            padding: 20px;
            border-radius: 5px;
            margin: 20px 0;
            text-align: center;
        }
        .decision-box.approved {
            background-color: #d4edda;
            border: 1px solid #c3e6cb;
            color: #155724;
        }
        .decision-box.rejected {
            background-color: #f8d7da;
            border: 1px solid #f5c6cb;
            color: #721c24;
        }
        .decision-box.conditional {
            background-color: #fff3cd;
            border: 1px solid #ffeaa7;
            color: #856404;
        }
        .next-steps {
            background-color: #e3f2fd;
            padding: 15px;
            border-radius: 5px;
            border-left: 4px solid #2196f3;
            margin: 20px 0;
        }
        .conditions {
            background-color: #fff3cd;
            padding: 15px;
            border-radius: 5px;
            border-left: 4px solid #ffc107;
            margin: 20px 0;
        }
        .button {
            display: inline-block;
            background-color: #007bff;
            color: white;
            padding: 12px 24px;
            text-decoration: none;
            border-radius: 5px;
            margin: 10px 0;
        }
        .button.success {
            background-color: #28a745;
        }
    </style>
</head>
<body>
    <div class="header {{status}}">
        <h1>
            {{#if (eq status 'approved')}}✅ Application Approved{{/if}}
            {{#if (eq status 'conditionally_approved')}}⚠️ Conditional Approval{{/if}}
            {{#if (eq status 'rejected')}}❌ Application Decision{{/if}}
        </h1>
        <p>Your tenant screening application has been reviewed</p>
    </div>

    <div class="content">
        <h2>Hello {{applicantName}},</h2>
        
        <p>We have completed the review of your tenant screening application for {{propertyName}}.</p>

        <div class="decision-box {{status}}">
            <h2>{{decision}}</h2>
            <p><strong>Application Number:</strong> {{applicationNumber}}</p>
            <p><strong>Property:</strong> {{propertyName}}</p>
            <p><strong>Decision Date:</strong> {{decisionDate}}</p>
        </div>

        {{#if (eq status 'approved')}}
        <div class="next-steps">
            <h3>🎉 Congratulations!</h3>
            <p>{{nextSteps}}</p>
            <p><strong>What's Next:</strong></p>
            <ul>
                <li>We will contact you within 24 hours to schedule lease signing</li>
                <li>Please prepare your security deposit and first month's rent</li>
                <li>Bring a valid photo ID for lease execution</li>
                <li>Complete move-in inspection scheduling</li>
            </ul>
        </div>

        <div style="text-align: center; margin: 30px 0;">
            <a href="{{leaseUrl}}" class="button success">Proceed to Lease Signing</a>
        </div>
        {{/if}}

        {{#if (eq status 'conditionally_approved')}}
        <div class="conditions">
            <h3>📋 Approval Conditions</h3>
            <p>Your application has been approved subject to the following conditions:</p>
            {{#if conditions}}
            <ul>
                {{#each conditions}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
            {{/if}}
            <p><strong>Please contact us to discuss these conditions and proceed with your application.</strong></p>
        </div>

        <div class="next-steps">
            <h3>🚀 Next Steps</h3>
            <p>{{nextSteps}}</p>
        </div>

        <div style="text-align: center; margin: 30px 0;">
            <a href="{{contactUrl}}" class="button">Contact Us</a>
        </div>
        {{/if}}

        {{#if (eq status 'rejected')}}
        <div class="next-steps">
            <h3>📝 About This Decision</h3>
            <p>{{nextSteps}}</p>
            
            {{#if rejectionReason}}
            <p><strong>Reason:</strong> {{rejectionReason}}</p>
            {{/if}}
            
            <p><strong>Your Options:</strong></p>
            <ul>
                <li>You may appeal this decision by providing additional documentation</li>
                <li>Apply for other available properties that might be a better fit</li>
                <li>Contact us to discuss improving your application for future opportunities</li>
            </ul>
        </div>

        <div style="text-align: center; margin: 30px 0;">
            <a href="{{propertiesUrl}}" class="button">View Other Properties</a>
        </div>
        {{/if}}

        <p><strong>Questions?</strong> If you have any questions about this decision or would like to discuss your options, please contact our leasing team.</p>

        <p>Thank you for your interest in our property.</p>

        <p>Best regards,<br>
        Property Management Team</p>
    </div>

    <div class="footer">
        <p>&copy; 2024 Property Management System. All rights reserved.</p>
        <p>This is an automated message. Please do not reply to this email.</p>
    </div>
</body>
</html>
